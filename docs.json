{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ClubSpeed",
  "colors": {
    "primary": "#df272d",
    "light": "#f04349",
    "dark": "#b81e23"
  },
  "font": {
    "headings": {
      "family": "Open Sans",
      "weight": 700
    },
    "body": {
      "family": "Open Sans",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "pagination",
              "expanding-objects",
              "errors",
              "idempotency",
              "webhooks",
              "metadata"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "api-reference/openapi.yaml",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "ClubSpeed.com",
          "href": "https://clubspeed.com",
          "icon": "globe"
        },
        {
          "anchor": "Support",
          "href": "https://clubspeed.com/support",
          "icon": "life-ring"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "ClubSpeed.com",
        "href": "https://clubspeed.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://clubspeed.com/login"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/Club_Speed",
      "linkedin": "https://linkedin.com/company/clubspeed",
      "instagram": "https://instagram.com/club_speed",
      "facebook": "https://facebook.com/ClubSpeed",
      "youtube": "https://youtube.com/channel/UCqD4K8QlxqmrgxsWu7qydlA"
    }
  }
}
