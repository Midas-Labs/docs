          {
            "group": "Core concepts",
            "pages": [
              "pagination",
              "expanding-objects",
              "errors",
              "idempotency",
              "webhooks",
              "metadata",
              "rate-limits",
              "versioning"
            ]
          },
          {
            "group": "Tutorials",
            "pages": [
              "tutorials/booking-integration",
              "tutorials/payment-processing",
              "tutorials/customer-management",
              "tutorials/products-catalog",
              "tutorials/scheduling-availability",
              "tutorials/racing-leaderboards",
              "tutorials/embed-booking-widget",
              "tutorials/memberships-loyalty",
              "tutorials/promotions-gift-cards",
              "tutorials/pos-integration",
              "tutorials/walkins-waitlist",
              "tutorials/venue-setup",
